{
  "expo": {
    "name": "validate-facil",
    "slug": "validate-facil",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/icons/icon.png",
    "scheme": "validatefacil",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./src/assets/icons/expo.icon"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./src/assets/icons/android-icon-foreground.png",
        "backgroundImage": "./src/assets/icons/android-icon-background.png",
        "monochromeImage": "./src/assets/icons/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.validatefacil"
    },
    "web": {
      "output": "single",
      "favicon": "./src/assets/icons/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./src/assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Permita que $(PRODUCT_NAME) use a câmera para escanear códigos de barras.",
          "recordAudioAndroid": false,
          "barcodeScannerEnabled": true
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Permita que $(PRODUCT_NAME) acesse suas fotos para associar imagens aos produtos.",
          "cameraPermission": "Permita que $(PRODUCT_NAME) use a câmera para fotografar produtos.",
          "microphonePermission": false
        }
      ],
      "expo-image"
    ],
    "experiments": {
      "reactCompiler": true
    }
  }
}
